# CPSC 368 – Group 4
## Phase 4 – Creating JSON files from ANES datasets     
This notebook creates JSON files from cleaned ANES csv files.
import csv
import json
import pandas as pd
# 1. create JSON of ANES data
anes2024 = pd.read_csv('anes_2024_clean_sample.csv')
anes2020 = pd.read_csv('anes_2020_clean_sample.csv')

# we will delete the column of the year and will create a separate key in our JSON structure

anes2024 = anes2024.drop(columns = ['election_year'])
anes2020 = anes2020.drop(columns = ['election_year'])
# 2. Convert to JSON 
anes2024_json = anes2024.to_json('anes_2024_clean_sample.json', orient='records', indent=4)
anes2020_json = anes2020.to_json('anes_2020_clean_sample.json', orient='records', indent=4)
# 3. load the content of JSON files
with open('anes_2024_clean_sample.json', 'r') as f_24:
    data_2024 = json.load(f_24)

with open('anes_2020_clean_sample.json', 'r') as f_20:
    data_2020 = json.load(f_20)

# 4. Create combined JSON file
combined = {
    "results_2024": {"election_year": 2024,
                     "stat": data_2024},
    "results_2020": {"election_year": 2020,
                     "stat": data_2020}
}

# 5. Save to a new file
with open('anes_combined.json', 'w') as f_comb:
    json.dump(combined, f_comb, indent=4, ensure_ascii=False)

print("done")
